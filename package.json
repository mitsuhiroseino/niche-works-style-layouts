{
  "name": "@niche-works/style-layouts",
  "version": "0.1.0",
  "private": true,
  "keywords": [
    "css",
    "style",
    "layout"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mitsuhiroseino/niche-works-style-layouts.git"
  },
  "license": "MIT",
  "author": "Mitsuhiro Seino",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts",
    "./constants": "./src/constants.ts",
    "./*/constants": "./src/*/constants.ts",
    "./styles.scss": "./styles.scss",
    "./stack.scss": "./stack/stack.scss",
    "./flow.scss": "./flow/flow.scss",
    "./matrix.scss": "./matrix/matrix.scss",
    "./tile.scss": "./tile/tile.scss",
    "./balance.scss": "./balance/balance.scss",
    "./pack.scss": "./pack/pack.scss",
    "./pin.scss": "./pin/pin.scss"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "scripts": {
    "build": "tsdown",
    "build-storybook": "storybook build",
    "check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "indexes": "tsx scripts/indexes.ts",
    "storybook": "storybook dev -p 6006",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "tidy": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" --config ./prettier.tidy.config.js"
  },
  "dependencies": {
    "@niche-works/types": "^0.3.1",
    "@niche-works/utils": "^0.4.0",
    "clsx": "^2.1.1",
    "csstype": "^3.2.3",
    "remeda": "^2.33.6",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^10.0.1",
    "@niche-works/dev": "^0.5.1",
    "@niche-works/rollup-plugin-dist-package": "^0.1.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/web-components-vite": "^10.3.6",
    "@tsdown/css": "^0.22.0",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^25.5.0",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "chroma-js": "^3.2.0",
    "eslint": "^10.3.0",
    "fast-glob": "^3.3.3",
    "lit": "^3.3.2",
    "lit-html": "^3.3.2",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "rimraf": "^6.1.3",
    "rollup-plugin-copy": "^3.5.0",
    "sass": "^1.99.0",
    "storybook": "^10.3.6",
    "tsdown": "^0.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@10.32.1"
}
